// This is your Prisma schema file.
// The app uses FastAPI + SQLAlchemy for its database (mini-services/api/).
// Prisma is retained for the db client import in src/lib/db.ts but the schema
// is intentionally empty of models — the real models live in the FastAPI
// models.py file. This prevents Prisma's db:push from trying to drop the
// FastAPI-created tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
